import { useState, useEffect } from 'react';
import { BrowserRouter as Router, Routes, Route, Navigate } from 'react-router-dom';
import { useAuth } from './useAuth';
import { useAdminAuth } from './useAdminAuth';
import Dashboard from './Dashboard';
import Login from './Login';
import AdminLogin from './AdminLogin';
import AdminRegister from './AdminRegister';

export default function App() {
  const { currentUser, login: userLogin, register: userRegister, logout: userLogout } = useAuth();
  const { currentAdmin, login: adminLogin, register: adminRegister, logout: adminLogout, isLoading } = useAdminAuth();

  if (isLoading) {
    return (
      <div className="min-h-screen bg-gradient-to-br from-indigo-50 via-slate-50 to-blue-50 flex items-center justify-center">
        <div className="text-center">
          <div className="w-12 h-12 border-4 border-indigo-200 border-t-indigo-600 rounded-full animate-spin mx-auto mb-4"></div>
          <p className="text-slate-600 font-medium">Carregando...</p>
        </div>
      </div>
    );
  }

  return (
    <Router basename="/distribuidora17">
      <Routes>
        {/* Admin routes */}
        {currentAdmin ? (
          <>
            <Route path="/admin" element={<Dashboard />} />
            <Route path="*" element={<Navigate to="/admin" />} />
          </>
        ) : (
          <>
            <Route path="/admin/login" element={<AdminLogin onLogin={adminLogin} />} />
            <Route path="/admin/cadastro" element={<AdminRegister onRegister={adminRegister} />} />
            <Route path="/admin/*" element={<Navigate to="/admin/login" />} />
            
            {/* User routes */}
            {currentUser ? (
              <>
                <Route path="/" element={<Dashboard />} />
                <Route path="*" element={<Navigate to="/" />} />
              </>
            ) : (
              <>
                <Route path="/login" element={<Login />} />
                <Route path="/" element={<Navigate to="/login" />} />
                <Route path="*" element={<Navigate to="/login" />} />
              </>
            )}
          </>
        )}
      </Routes>
    </Router>
  );
}
