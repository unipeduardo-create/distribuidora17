import { useState, useRef } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
  Upload, FileSpreadsheet, X, CheckCircle2, AlertCircle,
  Download, FileText, Users as UsersIcon
} from 'lucide-react';
import * as XLSX from 'xlsx';
import type { User } from '../../types';

interface ImportData {
  name: string;
  address: string;
  location: string;
  observation: string;
  isOpen: boolean;
  rowNumber: number;
  valid: boolean;
  error?: string;
}

interface ImportModalProps {
  isOpen: boolean;
  users: User[];
  onClose: () => void;
  onImport: (
    data: Array<{
      name: string;
      address: string;
      location: string;
      observation: string;
      isOpen: boolean;
      photo: string | null;
      userId: string;
      userName?: string;
      userEmail?: string;
    }>
  ) => void;
}

export default function ImportModal({ isOpen, users, onClose, onImport }: ImportModalProps) {
  const [step, setStep] = useState<'upload' | 'preview' | 'result'>('upload');
  const [importedData, setImportedData] = useState<ImportData[]>([]);
  const [selectedUserId, setSelectedUserId] = useState<string>(users[0]?.id || '');
  const [fileName, setFileName] = useState('');
  const [error, setError] = useState('');
  const [importResult, setImportResult] = useState<{ success: number; failed: number } | null>(null);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const reset = () => {
    setStep('upload');
    setImportedData([]);
    setFileName('');
    setError('');
    setImportResult(null);
    if (fileInputRef.current) fileInputRef.current.value = '';
  };

  const handleClose = () => {
    reset();
    onClose();
  };

  const parseStatus = (value: any): boolean => {
    if (typeof value === 'boolean') return value;
    const str = String(value || '').toLowerCase().trim();
    if (['aberta', 'aberto', 'open', 'sim', 'yes', 's', 'y', '1', 'true'].includes(str)) return true;
    if (['fechada', 'fechado', 'closed', 'não', 'no', 'n', '0', 'false', ''].includes(str)) return false;
    return false;
  };

  const handleFileUpload = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;

    setError('');
    setFileName(file.name);

    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const data = new Uint8Array(event.target?.result as ArrayBuffer);
        const workbook = XLSX.read(data, { type: 'array' });

        // Tenta encontrar a primeira aba útil (Distribuidoras, Planilha1, ou primeira)
        const sheetName =
          workbook.SheetNames.find((n) => n.toLowerCase().includes('distribuidora')) ||
          workbook.SheetNames[0];

        const worksheet = workbook.Sheets[sheetName];
        const jsonData = XLSX.utils.sheet_to_json(worksheet, { defval: '' }) as Record<string, any>[];

        if (jsonData.length === 0) {
          setError('O arquivo está vazio ou não contém dados válidos.');
          return;
        }

        // Mapeamento flexível de colunas
        const parsed: ImportData[] = jsonData.map((row, index) => {
          const findValue = (keys: string[]) => {
            for (const key of keys) {
              const foundKey = Object.keys(row).find(
                (k) => k.toLowerCase().trim() === key.toLowerCase()
              );
              if (foundKey !== undefined) return row[foundKey];
            }
            return '';
          };

          const name = String(findValue(['Nome da Distribuidora', 'Nome', 'name']) || '').trim();
          const address = String(findValue(['Endereço', 'Endereco', 'Address']) || '').trim();
          const location = String(findValue(['Localização (Coordenadas)', 'Localização', 'Localizacao', 'Coordenadas', 'Location']) || '').trim();
          const observation = String(findValue(['Observação', 'Observacao', 'Observações', 'Observation', 'Notas', 'Notes']) || '').trim();
          const statusRaw = findValue(['Status', 'Aberta', 'Estado']);

          const valid = name.length > 0 && address.length > 0;
          const isOpen = parseStatus(statusRaw);

          return {
            name,
            address,
            location,
            observation,
            isOpen,
            rowNumber: index + 2, // +2 porque a linha 1 é o cabeçalho
            valid,
            error: !valid
              ? !name
                ? 'Nome obrigatório'
                : 'Endereço obrigatório'
              : undefined,
          };
        });

        setImportedData(parsed);
        setStep('preview');
      } catch (err) {
        setError('Erro ao processar o arquivo. Verifique se o formato é válido (Excel ou CSV).');
        console.error(err);
      }
    };
    reader.readAsArrayBuffer(file);
  };

  const handleImport = () => {
    const validItems = importedData.filter((d) => d.valid);
    if (validItems.length === 0) {
      setError('Nenhum item válido para importar.');
      return;
    }

    const selectedUser = users.find((u) => u.id === selectedUserId);

    const toImport = validItems.map((item) => ({
      name: item.name,
      address: item.address,
      location: item.location,
      observation: item.observation,
      isOpen: item.isOpen,
      photo: null,
      userId: selectedUserId,
      userName: selectedUser?.name,
      userEmail: selectedUser?.email,
    }));

    onImport(toImport);
    setImportResult({
      success: validItems.length,
      failed: importedData.length - validItems.length,
    });
    setStep('result');
  };

  const downloadTemplate = () => {
    const templateData = [
      {
        'Nome da Distribuidora': 'Distribuidora Exemplo',
        'Endereço': 'Rua das Flores, 123 - Centro',
        'Localização (Coordenadas)': '-23.550520, -46.633308',
        'Observação': 'Funciona de segunda a sábado, das 8h às 18h',
        'Status': 'Aberta',
      },
    ];

    const wb = XLSX.utils.book_new();
    const ws = XLSX.utils.json_to_sheet(templateData);
    ws['!cols'] = [{ wch: 28 }, { wch: 40 }, { wch: 28 }, { wch: 50 }, { wch: 12 }];
    XLSX.utils.book_append_sheet(wb, ws, 'Distribuidoras');
    XLSX.writeFile(wb, 'modelo_importacao_distribuidoras.xlsx');
  };

  const validCount = importedData.filter((d) => d.valid).length;
  const invalidCount = importedData.length - validCount;

  return (
    <AnimatePresence>
      {isOpen && (
        <motion.div
          initial={{ opacity: 0 }}
          animate={{ opacity: 1 }}
          exit={{ opacity: 0 }}
          className="fixed inset-0 bg-black/40 backdrop-blur-sm flex items-center justify-center z-50 p-4"
          onClick={handleClose}
        >
          <motion.div
            initial={{ scale: 0.95, opacity: 0 }}
            animate={{ scale: 1, opacity: 1 }}
            exit={{ scale: 0.95, opacity: 0 }}
            onClick={(e) => e.stopPropagation()}
            className="bg-white rounded-xl shadow-2xl w-full max-w-2xl max-h-[90vh] overflow-hidden flex flex-col"
          >
            {/* Header */}
            <div className="flex items-center justify-between px-6 py-4 border-b border-slate-200 bg-gradient-to-r from-indigo-50 to-emerald-50">
              <div className="flex items-center gap-3">
                <div className="w-10 h-10 bg-indigo-100 rounded-lg flex items-center justify-center">
                  <FileSpreadsheet className="w-5 h-5 text-indigo-600" />
                </div>
                <div>
                  <h2 className="text-lg font-bold text-slate-800">Importar Distribuidoras</h2>
                  <p className="text-xs text-slate-500">
                    {step === 'upload' && 'Passo 1 de 3 — Envie o arquivo'}
                    {step === 'preview' && 'Passo 2 de 3 — Revise os dados'}
                    {step === 'result' && 'Passo 3 de 3 — Importação concluída'}
                  </p>
                </div>
              </div>
              <button
                onClick={handleClose}
                className="text-slate-400 hover:text-slate-600 transition-colors"
              >
                <X className="w-5 h-5" />
              </button>
            </div>

            {/* Content */}
            <div className="flex-1 overflow-y-auto p-6">
              {/* STEP 1: Upload */}
              {step === 'upload' && (
                <div className="space-y-4">
                  <div>
                    <h3 className="text-sm font-semibold text-slate-700 mb-2">
                      Formato do arquivo
                    </h3>
                    <p className="text-sm text-slate-500">
                      Aceita arquivos <strong>.xlsx</strong>, <strong>.xls</strong> ou <strong>.csv</strong> com as
                      seguintes colunas (a ordem não importa):
                    </p>
                    <ul className="mt-2 space-y-1 text-xs text-slate-600 bg-slate-50 p-3 rounded-lg">
                      <li>• <strong>Nome da Distribuidora</strong> (obrigatório)</li>
                      <li>• <strong>Endereço</strong> (obrigatório)</li>
                      <li>• <strong>Localização (Coordenadas)</strong> (opcional)</li>
                      <li>• <strong>Observação</strong> (opcional)</li>
                      <li>• <strong>Status</strong> — "Aberta" ou "Fechada" (padrão: Fechada)</li>
                    </ul>
                  </div>

                  <button
                    onClick={downloadTemplate}
                    className="w-full flex items-center justify-center gap-2 py-2.5 bg-emerald-50 hover:bg-emerald-100 border border-emerald-200 text-emerald-700 text-sm font-medium rounded-lg transition-colors"
                  >
                    <Download className="w-4 h-4" />
                    Baixar modelo de exemplo (.xlsx)
                  </button>

                  <div>
                    <label className="block text-sm font-medium text-slate-700 mb-2">
                      Selecionar arquivo
                    </label>
                    <div
                      onClick={() => fileInputRef.current?.click()}
                      className="border-2 border-dashed border-slate-300 hover:border-indigo-400 rounded-xl p-8 text-center cursor-pointer transition-colors bg-slate-50 hover:bg-indigo-50/30"
                    >
                      <Upload className="w-10 h-10 text-slate-400 mx-auto mb-2" />
                      <p className="text-sm font-medium text-slate-700">
                        Clique para selecionar ou arraste o arquivo aqui
                      </p>
                      <p className="text-xs text-slate-400 mt-1">
                        Excel (.xlsx, .xls) ou CSV (.csv)
                      </p>
                      <input
                        ref={fileInputRef}
                        type="file"
                        accept=".xlsx,.xls,.csv"
                        onChange={handleFileUpload}
                        className="hidden"
                      />
                    </div>
                    {fileName && (
                      <div className="mt-3 flex items-center gap-2 text-sm text-slate-600">
                        <FileText className="w-4 h-4 text-emerald-600" />
                        <span>{fileName}</span>
                      </div>
                    )}
                  </div>

                  {error && (
                    <div className="flex items-start gap-2 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                      <AlertCircle className="w-4 h-4 mt-0.5 shrink-0" />
                      <span>{error}</span>
                    </div>
                  )}
                </div>
              )}

              {/* STEP 2: Preview */}
              {step === 'preview' && (
                <div className="space-y-4">
                  <div className="flex items-center justify-between">
                    <div>
                      <h3 className="text-sm font-semibold text-slate-700">
                        Preview da importação
                      </h3>
                      <p className="text-xs text-slate-500 mt-0.5">
                        <span className="text-emerald-600 font-medium">{validCount} válido{validCount !== 1 ? 's' : ''}</span>
                        {' • '}
                        <span className="text-red-600 font-medium">{invalidCount} com erro{invalidCount !== 1 ? 's' : ''}</span>
                        {' • '}
                        Arquivo: {fileName}
                      </p>
                    </div>
                    <button
                      onClick={() => {
                        reset();
                      }}
                      className="text-xs text-indigo-600 hover:text-indigo-700 font-medium"
                    >
                      Trocar arquivo
                    </button>
                  </div>

                  <div>
                    <label className="block text-sm font-medium text-slate-700 mb-1.5">
                      Atribuir ao usuário:
                    </label>
                    <div className="relative">
                      <UsersIcon className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" />
                      <select
                        value={selectedUserId}
                        onChange={(e) => setSelectedUserId(e.target.value)}
                        className="w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent appearance-none cursor-pointer"
                      >
                        {users.map((u) => (
                          <option key={u.id} value={u.id}>
                            {u.name} ({u.email})
                          </option>
                        ))}
                      </select>
                    </div>
                    <p className="text-xs text-slate-400 mt-1">
                      Todas as distribuidoras importadas serão vinculadas ao usuário selecionado.
                    </p>
                  </div>

                  <div className="border border-slate-200 rounded-lg overflow-hidden max-h-80 overflow-y-auto">
                    <table className="w-full text-xs">
                      <thead className="bg-slate-50 sticky top-0">
                        <tr>
                          <th className="text-left px-3 py-2 font-semibold text-slate-600">#</th>
                          <th className="text-left px-3 py-2 font-semibold text-slate-600">Nome</th>
                          <th className="text-left px-3 py-2 font-semibold text-slate-600">Endereço</th>
                          <th className="text-left px-3 py-2 font-semibold text-slate-600">Status</th>
                          <th className="text-left px-3 py-2 font-semibold text-slate-600">Status</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-slate-100">
                        {importedData.map((item) => (
                          <tr
                            key={item.rowNumber}
                            className={item.valid ? 'hover:bg-slate-50' : 'bg-red-50/50'}
                          >
                            <td className="px-3 py-2 text-slate-400">{item.rowNumber}</td>
                            <td className="px-3 py-2">
                              <div className="font-medium text-slate-800 truncate max-w-[150px]">
                                {item.name || <span className="text-red-400 italic">vazio</span>}
                              </div>
                            </td>
                            <td className="px-3 py-2">
                              <div className="text-slate-600 truncate max-w-[180px]">
                                {item.address || <span className="text-red-400 italic">vazio</span>}
                              </div>
                            </td>
                            <td className="px-3 py-2">
                              <span
                                className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium ${
                                  item.isOpen
                                    ? 'bg-emerald-100 text-emerald-700'
                                    : 'bg-red-100 text-red-700'
                                }`}
                              >
                                {item.isOpen ? 'Aberta' : 'Fechada'}
                              </span>
                            </td>
                            <td className="px-3 py-2">
                              {item.valid ? (
                                <CheckCircle2 className="w-4 h-4 text-emerald-500" />
                              ) : (
                                <span className="text-red-500 text-[10px]">{item.error}</span>
                              )}
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>

                  {error && (
                    <div className="flex items-start gap-2 p-3 bg-red-50 border border-red-200 rounded-lg text-sm text-red-700">
                      <AlertCircle className="w-4 h-4 mt-0.5 shrink-0" />
                      <span>{error}</span>
                    </div>
                  )}
                </div>
              )}

              {/* STEP 3: Result */}
              {step === 'result' && importResult && (
                <div className="text-center py-6 space-y-4">
                  <div className="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto">
                    <CheckCircle2 className="w-8 h-8 text-emerald-600" />
                  </div>
                  <div>
                    <h3 className="text-lg font-bold text-slate-800">Importação concluída!</h3>
                    <p className="text-sm text-slate-500 mt-1">
                      O processo foi finalizado com sucesso.
                    </p>
                  </div>

                  <div className="grid grid-cols-2 gap-3 max-w-sm mx-auto">
                    <div className="bg-emerald-50 border border-emerald-200 rounded-lg p-3">
                      <p className="text-2xl font-bold text-emerald-600">{importResult.success}</p>
                      <p className="text-xs text-emerald-700">importada{importResult.success !== 1 ? 's' : ''}</p>
                    </div>
                    <div className="bg-red-50 border border-red-200 rounded-lg p-3">
                      <p className="text-2xl font-bold text-red-600">{importResult.failed}</p>
                      <p className="text-xs text-red-700">ignorada{importResult.failed !== 1 ? 's' : ''}</p>
                    </div>
                  </div>

                  <p className="text-xs text-slate-500">
                    Arquivo processado: <strong>{fileName}</strong>
                  </p>
                </div>
              )}
            </div>

            {/* Footer */}
            <div className="flex items-center justify-between px-6 py-4 border-t border-slate-200 bg-slate-50">
              {step === 'upload' && (
                <>
                  <button
                    onClick={handleClose}
                    className="px-4 py-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-700 font-medium rounded-lg transition-colors text-sm"
                  >
                    Cancelar
                  </button>
                  <div className="text-xs text-slate-400">
                    Aguarde o processamento do arquivo
                  </div>
                </>
              )}

              {step === 'preview' && (
                <>
                  <button
                    onClick={() => {
                      reset();
                    }}
                    className="px-4 py-2 bg-white hover:bg-slate-100 border border-slate-200 text-slate-700 font-medium rounded-lg transition-colors text-sm"
                  >
                    Voltar
                  </button>
                  <button
                    onClick={handleImport}
                    disabled={validCount === 0}
                    className="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 disabled:bg-indigo-300 text-white font-medium rounded-lg transition-colors text-sm"
                  >
                    <Upload className="w-4 h-4" />
                    Importar {validCount} distribuidora{validCount !== 1 ? 's' : ''}
                  </button>
                </>
              )}

              {step === 'result' && (
                <button
                  onClick={handleClose}
                  className="w-full py-2 bg-emerald-600 hover:bg-emerald-700 text-white font-medium rounded-lg transition-colors text-sm"
                >
                  Fechar
                </button>
              )}
            </div>
          </motion.div>
        </motion.div>
      )}
    </AnimatePresence>
  );
}
